# Development overrides.
# In production these are baked in at build time via src/config.ts defaults.

# Embed-gateway token endpoint.
VITE_API_URL=http://localhost:8787

# Voice-runtime WSS endpoint (the token response also carries a wssUrl that wins
# at runtime; this is just the fallback when the API is unreachable in local dev).
VITE_WSS_URL=ws://localhost:8788/embed/v1/call
