# =============================================================================
# embed-sdk — environment variables
# =============================================================================
# The SDK is a Vite library bundle. Customers don't see these variables —
# they're only used by the local dev/example app under examples/ to point at
# a local mock backend instead of the production endpoints.
#
# The production defaults are baked into src/config.ts and DO NOT come from
# env vars at customer build time:
#   DEFAULT_API_URL = https://embed.vocadesk.com         (embed-gateway)
#   DEFAULT_WSS_URL = wss://voice.vocadesk.com/embed/v1/call  (voice-runtime2)
#
# These constants are stable; changing them would break every embedded
# customer snippet, so don't.
# =============================================================================

# Embed-gateway token endpoint (overrides DEFAULT_API_URL for local dev only).
# Use the port your local embed-gateway is listening on (default 8080),
# or a mock server.
VITE_API_URL=http://localhost:8787

# Voice-runtime WSS endpoint (overrides DEFAULT_WSS_URL for local dev only).
# Note: the token response also carries a wssUrl that wins at runtime —
# this only matters when the gateway is unreachable in local dev.
# Use the port your local voice-runtime2 is listening on (default 8000)
# under the /embed/v1/call route.
VITE_WSS_URL=ws://localhost:8788/embed/v1/call
